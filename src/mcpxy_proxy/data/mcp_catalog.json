  "entries": [
    {
      "id": "filesystem",
      "name": "Filesystem",
      "description": "Read, write, and search files in a sandboxed directory on the local filesystem.",
      "category": "storage",
      "homepage": "https://github.com/modelcontextprotocol/servers/tree/main/src/filesystem",
      "transport": "stdio",
      "install_hint": "Requires Node.js (npx).",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-filesystem", "${allowed_path}"],
      "variables": [
        {
          "name": "allowed_path",
          "description": "Absolute path the server is allowed to access.",
          "required": true,
          "default": "/tmp"
        }
      ],
      "tags": ["files", "local", "storage"]
    },
    {
      "id": "git",
      "name": "Git",
      "description": "Inspect a local Git repository: status, log, diff, blame, show.",
      "category": "developer",
      "homepage": "https://github.com/modelcontextprotocol/servers/tree/main/src/git",
      "transport": "stdio",
      "install_hint": "Requires uvx (pip install uv).",
      "command": "uvx",
      "args": ["mcp-server-git", "--repository", "${repo_path}"],
      "variables": [
        {
          "name": "repo_path",
          "description": "Absolute path to the Git repository.",
          "required": true
        }
      ],
      "tags": ["git", "vcs", "developer"]
    },
    {
      "id": "github",
      "name": "GitHub",
      "description": "Read and write GitHub issues, pull requests, repositories, and search.",
      "category": "developer",
      "homepage": "https://github.com/modelcontextprotocol/servers/tree/main/src/github",
      "transport": "stdio",
      "install_hint": "Requires Node.js (npx) and a GitHub personal access token.",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-github"],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "${github_token}"
      },
      "variables": [
        {
          "name": "github_token",
          "description": "GitHub personal access token (PAT).",
          "required": true,
          "secret": true
        }
      ],
      "tags": ["github", "git", "developer", "api"]
    },
    {
      "id": "gitlab",
